FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    //- Set patchGroups for constraint patches
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type            calculated;
        value           uniform 0;
    }

    outlet
    {
        type            calculated;
        value           uniform 0;
    }

    "(lowerWall|upperWall)"
    {
        type            calculated;
        value           uniform 0;
    }

    bridge
    {
        //type            nutkWallFunction;
        type            nutkRoughWallFunction;
        Ks              uniform 0.001;   // roughness height [m]
        Cs              uniform 0.5;     // roughness constant [-]
        value           uniform 0;
    }
}


