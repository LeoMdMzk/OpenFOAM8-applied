FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      extrudeMeshDict;
}
/*********** system/extrudeMeshDict ***********/

constructFrom patch;

sourceCase ".";                // or "../my3DCase"
sourcePatches (emptyFront);          // patch from the snappy mesh you want to extrude
exposedPatchName emptyBack;         // name for the opposite patch

extrudeModel linearNormal;

nLayers 1;                     // 1 cell in the extrusion direction = 2D case

linearNormalCoeffs
{
    thickness 1;               // arbitrary physical thickness
}

mergeFaces false;
flipNormals yes;